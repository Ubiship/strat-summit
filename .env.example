# Strathcona Summit Solutions - Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Email (Resend)
# ===================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_EMAIL=hello@strathconasummit.com

# Verified sender in Resend (e.g. Strathcona Summit <hello@strathconasummit.com>)
RESEND_FROM_EMAIL=Strathcona Summit <onboarding@resend.dev>

# ===================
# Site Configuration
# ===================
# Base URL for the site (used for metadata, OG images)
NEXT_PUBLIC_SITE_URL=https://strathconasummit.com
